alias nm-l="nmcli dev wifi list"
alias nm-u="nmcli con up"
alias rename="rename -o"
alias lf="lfrun"
alias jpwine="WINEPREFIX=\"$PWD/pfx\" LANG=ja_JP.UTF-8 wine"
alias headp="paswitch alsa_output.pci-0000_00_1b.0.analog-stereo"
alias fm="clifm --no-welcome-message"
alias chromium="chromium --enable-dark-mode --enable-features=WebUIDarkMode --enable-features=VaapiVideoDecoder --use-gl=egl"

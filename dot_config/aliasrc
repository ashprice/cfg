alias	magit="nvim -c MagitOnly"
alias	p="sudo pacman"
alias	SS="sudo systemctl"
alias	f="$FILE"
alias	g="git"
alias	trem="transmission-remote"
alias	e="$EDITOR"
alias	v="$EDITOR"
alias	x="sxiv -ft *"
